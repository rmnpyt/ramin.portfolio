---
const { basics } = Astro.props;
const year = new Date().getFullYear();
---
<footer class="footer">
  <p>
    © {year} {basics.name} ·
    {basics.links.github && <> <a href={basics.links.github} target="_blank" rel="noopener">GitHub</a> ·</>}
    {basics.links.linkedin && <> <a href={basics.links.linkedin} target="_blank" rel="noopener">LinkedIn</a></>}
  </p>
</footer>
