---
const { label, loadingLabel, noReposLabel, loadErrorLabel } = Astro.props;
const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "";
---
<section class="section reveal" id="projects">
  <div class="container">
    <h2>{label}</h2>
    <div id="projects-status" class="status">{loadingLabel}</div>
    <div id="projects-grid" class="projects-grid"></div>
  </div>
</section>

<script define:vars={{ apiBase, noReposLabel, loadErrorLabel }}>
  const FETCH_TIMEOUT_MS = 8000;

  async function loadRepos() {
    const statusEl = document.getElementById("projects-status");
    const gridEl = document.getElementById("projects-grid");
    if (!statusEl || !gridEl) return;

    statusEl.textContent = statusEl.dataset.loadingText || statusEl.textContent;
    gridEl.innerHTML = "";

    const controller = new AbortController();
    const timeoutId = setTimeout(() => controller.abort(), FETCH_TIMEOUT_MS);

    try {
      const res = await fetch(`${apiBase}/api/repos`, { signal: controller.signal });
      clearTimeout(timeoutId);
      if (!res.ok) throw new Error(`Request failed: ${res.status}`);
      const repos = await res.json();

      if (repos.length === 0) {
        statusEl.textContent = noReposLabel;
        return;
      }

      statusEl.remove();
      gridEl.innerHTML = repos
        .map(
          (repo) => `
        <a class="project-card" href="${repo.url}" target="_blank" rel="noopener">
          <h3>${repo.name}</h3>
          <p>${repo.description ?? ""}</p>
          <div class="project-meta">
            ${repo.language ? `<span><span class="lang-dot"></span>${repo.language}</span>` : ""}
            <span>★ ${repo.stars}</span>
          </div>
        </a>`
        )
        .join("");
    } catch (err) {
      clearTimeout(timeoutId);
      statusEl.innerHTML = "";
      statusEl.append(document.createTextNode(loadErrorLabel + " "));
      const retryBtn = document.createElement("button");
      retryBtn.type = "button";
      retryBtn.className = "retry-btn";
      retryBtn.textContent = "↻";
      retryBtn.addEventListener("click", loadRepos);
      statusEl.append(retryBtn);
      console.error(err);
    }
  }

  loadRepos();
</script>
