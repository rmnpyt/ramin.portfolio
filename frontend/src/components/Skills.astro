---
const { skills, label } = Astro.props;
---
<section class="section reveal" id="skills">
  <div class="container">
    <h2>{label}</h2>
    <div class="skills-grid">
      {skills.map((group: any) => (
        <div class="skill-group">
          <h4>{group.category}</h4>
          <ul class="tag-list">
            {group.items.map((item: string) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
