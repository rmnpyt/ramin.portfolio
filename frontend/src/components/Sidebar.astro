---
import fs from "node:fs";
import path from "node:path";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const { basics, labels, currentLocale } = Astro.props;

const PHOTO_CANDIDATES = ["profile.jpg", "profile.jpeg", "profile.png", "profile.webp"];
const publicDir = path.join(process.cwd(), "public");
const photoFile = PHOTO_CANDIDATES.find((name) => fs.existsSync(path.join(publicDir, name)));
const photoUrl = photoFile ? `/${photoFile}` : null;

const initials = basics.name
  .split(" ")
  .map((part: string) => part[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();
---
<aside class="sidebar">
  {photoUrl ? (
    <div class="avatar-photo">
      <img src={photoUrl} alt={basics.name} />
    </div>
  ) : (
    <div class="avatar-photo initials">{initials}</div>
  )}
  <h1>{basics.name}</h1>
  <p class="role">{basics.title}</p>

  <ul class="contact-list">
    <li>
      <span class="icon">✉</span>
      <div>
        <p class="label">{labels.emailLabel}</p>
        <a href={`mailto:${basics.email}`}>{basics.email}</a>
      </div>
    </li>
    <li>
      <span class="icon">📍</span>
      <div>
        <p class="label">{labels.locationLabel}</p>
        <span class="value">{basics.location}</span>
      </div>
    </li>
    {basics.phone && (
      <li>
        <span class="icon">☎</span>
        <div>
          <p class="label">{labels.phoneLabel}</p>
          <span class="value">{basics.phone}</span>
        </div>
      </li>
    )}
  </ul>

  <ul class="social-list">
    {basics.links.github && (
      <li>
        <a href={basics.links.github} target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M12 .5C5.73.5.5 5.73.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.87-1.36-3.87-1.36-.53-1.33-1.29-1.69-1.29-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.78 1.2 1.78 1.2 1.04 1.77 2.72 1.26 3.38.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.27-5.23-5.67 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.05 0 0 .96-.31 3.16 1.18a10.96 10.96 0 0 1 5.76 0c2.2-1.49 3.16-1.18 3.16-1.18.62 1.59.23 2.76.11 3.05.74.8 1.18 1.83 1.18 3.08 0 4.41-2.69 5.38-5.25 5.66.41.36.78 1.06.78 2.15 0 1.55-.01 2.8-.01 3.18 0 .3.21.66.79.55A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"/>
          </svg>
        </a>
      </li>
    )}
    {basics.links.linkedin && (
      <li>
        <a href={basics.links.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
            <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"/>
          </svg>
        </a>
      </li>
    )}
    {basics.links.website && (
      <li>
        <a href={basics.links.website} target="_blank" rel="noopener" aria-label="Website">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <path d="M2 12h20M12 2c2.5 2.7 4 6.2 4 10s-1.5 7.3-4 10c-2.5-2.7-4-6.2-4-10s1.5-7.3 4-10Z"/>
          </svg>
        </a>
      </li>
    )}
  </ul>

  <LanguageSwitcher currentLocale={currentLocale} />
</aside>
