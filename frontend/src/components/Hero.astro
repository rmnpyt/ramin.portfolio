---
const { basics, githubLabel, linkedinLabel } = Astro.props;
const initials = basics.name
  .split(" ")
  .map((part: string) => part[0])
  .slice(0, 2)
  .join("")
  .toUpperCase();
---
<header class="hero" id="top">
  <div class="hero-inner">
    <div class="avatar">{initials}</div>
    <h1>{basics.name}</h1>
    <p class="title">{basics.title}</p>
    <p class="summary">{basics.summary}</p>
    <div class="meta">
      <span>{basics.location}</span>
      {basics.phone && <span>{basics.phone}</span>}
    </div>
    <div class="cta-row">
      <a class="btn btn-primary" href={`mailto:${basics.email}`}>{basics.email}</a>
      {basics.links.github && <a class="btn" href={basics.links.github} target="_blank" rel="noopener">{githubLabel}</a>}
      {basics.links.linkedin && <a class="btn" href={basics.links.linkedin} target="_blank" rel="noopener">{linkedinLabel}</a>}
    </div>
    <a href="#experience" class="scroll-cue" aria-label="Scroll down">⌄</a>
  </div>
</header>
