---
import Sidebar from "../components/Sidebar.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Skills from "../components/Skills.astro";
import Certifications from "../components/Certifications.astro";
import Languages from "../components/Languages.astro";
import SoftSkills from "../components/SoftSkills.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import "../styles/global.css";
import { dir as dirMap, t, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
  cvData: any;
}

const { locale, cvData } = Astro.props as Props;
const labels = t(locale);
const direction = dirMap[locale];
const colorProfile = import.meta.env.PUBLIC_COLOR_PROFILE || "tealMagenta";
---
<html lang={locale} dir={direction} data-theme={colorProfile}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{cvData.basics.name} — {cvData.basics.title}</title>
  </head>
  <body>
    <div class="layout">
      <Sidebar basics={cvData.basics} labels={labels} currentLocale={locale} />

      <div class="content">
        <nav class="tabnav">
          <button class="tab active" data-tab="about">{labels.aboutNav}</button>
          <button class="tab" data-tab="resume">{labels.resumeNav}</button>
          <button class="tab" data-tab="portfolio">{labels.portfolioNav}</button>
          <button class="tab" data-tab="contact">{labels.contactNav}</button>
        </nav>

        <section class="panel active" data-panel="about">
          <p class="summary-block">{cvData.basics.summary}</p>
          <Skills skills={cvData.skills} label={labels.skills} />
          <SoftSkills softSkills={cvData.softSkills} label={labels.softSkills} />
          <Languages languages={cvData.languages} label={labels.languages} />
        </section>

        <section class="panel" data-panel="resume">
          <Experience experience={cvData.experience} label={labels.experience} presentLabel={labels.present} />
          <Education education={cvData.education} label={labels.education} />
          <Certifications certifications={cvData.certifications} label={labels.certifications} />
        </section>

        <section class="panel" data-panel="portfolio">
          <Projects
            label={labels.projects}
            loadingLabel={labels.loading}
            noReposLabel={labels.noRepos}
            loadErrorLabel={labels.loadError}
          />
        </section>

        <section class="panel" data-panel="contact">
          <Contact
            basics={cvData.basics}
            label={labels.contact}
            reachOut={labels.reachOut}
            orConnect={labels.orConnect}
            linkedinLabel={labels.linkedin}
          />
        </section>
      </div>
    </div>

    <script>
      const tabs = document.querySelectorAll(".tab");
      const panels = document.querySelectorAll(".panel");

      tabs.forEach((tabBtn) => {
        tabBtn.addEventListener("click", () => {
          const target = tabBtn.getAttribute("data-tab");

          tabs.forEach((t) => t.classList.remove("active"));
          tabBtn.classList.add("active");

          panels.forEach((panel) => {
            panel.classList.toggle("active", panel.getAttribute("data-panel") === target);
          });
        });
      });
    </script>
  </body>
</html>
